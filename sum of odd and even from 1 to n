#include <stdio.h>
void main()
{
    int i = 0, n, even = 0, odd = 0;
    printf("Enter n: ");
    scanf("%d", &n);
    while(i <= n)
    {
        if(i % 2 == 0)
        {
            even = even + i;
        }
        else
        {
            odd = odd + i;
        }
        i++;
    }
    printf("Sum of even numbers = %d\n", even);
    printf("Sum of odd numbers = %d\n", odd);
}
